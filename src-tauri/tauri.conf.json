{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sgltoolkit",
  "version": "0.1.0",
  "identifier": "com.lsw.sgltoolkit",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SGLToolKit V1.0",
        "width": 1240,
        "height": 900
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/32x32.ico"
    ]
  }
}
